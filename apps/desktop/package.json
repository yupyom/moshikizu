{
  "name": "@draw/desktop",
  "private": true,
  "version": "1.0.1",
  "description": "Moshikizu デスクトップシェル（Electron）",
  "main": "main.cjs",
  "scripts": {
    "dev": "electron . --dev",
    "start": "electron .",
    "package": "node scripts/copy-renderer.cjs && electron-builder --mac dir",
    "package:mac": "node scripts/copy-renderer.cjs && electron-builder --mac zip",
    "package:win": "node scripts/copy-renderer.cjs && electron-builder --win zip"
  },
  "build": {
    "appId": "jp.yupyom.moshikizu",
    "productName": "Moshikizu",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "mcpHost.cjs",
      "renderer/**"
    ],
    "mac": {
      "identity": null,
      "category": "public.app-category.graphics-design",
      "icon": "build/icon.icns"
    },
    "electronVersion": "43.0.0",
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "zip"
      ]
    }
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
