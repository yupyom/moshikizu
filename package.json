{
  "name": "draw",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @draw/web",
    "build": "npm run build -w @draw/web",
    "desktop": "npm run build -w @draw/web && npm run start -w @draw/desktop",
    "desktop:dev": "npm run dev -w @draw/desktop",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  }
}
